# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage
/playwright-report
/test-results

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Environment / secrets (DataForSEO key, etc. — never commit)
.env
.env.local

# Research pipeline outputs (regenerated, may be large)
/research/*.csv
/research/__pycache__/
*.py[cod]

# OS / editor
.idea/
.vscode/

# Research pipeline
/research/cache/
/research/.venv/
research/.env
/research/results/pull.json
/research/results/pull.log

# Brainstorm visual companion
.superpowers/
